# ============================================================
# JENTERA PINTAR P170 TUARAN - KONFIGURASI PRODUCTION
# ============================================================
# Salin fail ini ke .env dan isi nilai production
# cp .env.example .env
# ============================================================

# === MODE PRODUCTION ===
# Tukar ke "true" untuk production deployment
JENTERA_PRODUCTION=true

# === JWT SECURITY ===
# Guna kunci rawak yang kuat (min 32 aksara)
# Linux/Mac: openssl rand -hex 32
# Windows PowerShell: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
JENTERA_SECRET_KEY=ubah-ini-dengan-kunci-rawak-yang-sukar-diteka-32-aksara

# Tempoh token sah (dalam jam)
JENTERA_TOKEN_EXPIRE_HOURS=24

# === CORS ===
# Senarai domain yang dibenarkan (pisah dengan koma)
# Contoh: https://jentera-pintar-p170.vercel.app,https://jentera-pintar-p170-tuaran.vercel.app
JENTERA_ALLOWED_ORIGINS=https://jentera-pintar-p170-tuaran.vercel.app

# === DATABASE (SQLite - tempatan) ===
# Path ke fail database (guna path penuh untuk production)
# JENTERA_DB_PATH=C:/Data/pengundi.db

# === DATABASE (PostgreSQL / Supabase - production) ===
# Jika diset, sistem akan guna PostgreSQL dan ABAIKAN SQLite.
# Format: postgresql://user:password@host:5432/dbname
# DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

# === STATIC FILES ===
# Path ke folder dist hasil build (default: frontend/dist)
# JENTERA_STATIC_DIR=C:/path/to/frontend/dist

# === LOGGING ===
# Fail log untuk rujukan audit
# JENTERA_LOG_FILE=C:/Logs/jentera.log